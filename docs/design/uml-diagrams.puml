@startuml UML_ClassDiagram

' Concept #24 — UML Class Diagram
' Shows: classes, attributes, methods, relationships (association, composition,
'        aggregation, inheritance, realization, dependency)

title UML Class Diagram — ConceptualWare Core Domain

skinparam classAttributeIconSize 0
skinparam monochrome false

' ── User Domain ─────────────────────────────────────────────────────────────

class User {
    -id: String
    -email: String
    -passwordHash: String
    -role: UserRole
    -createdAt: Instant
    -totpSecret: String
    -mfaEnabled: boolean
    +isAdmin(): boolean
    +generateOtpUri(): String
}

enum UserRole {
    LEARNER
    CONTRIBUTOR
    ADMIN
}

class UserProgress {
    -userId: String
    -conceptId: String
    -completedAt: Instant
    -attempts: int
    -bestExecutionMs: long
    +isCompleted(): boolean
    +incrementAttempts(): void
}

class Leaderboard {
    -userId: String
    -score: long
    -rank: int
    -lastUpdated: Instant
    +updateScore(delta: long): void
}

' ── Concept Domain ───────────────────────────────────────────────────────────

abstract class Concept {
    #id: String
    #name: String
    #category: Category
    #difficulty: Difficulty
    #description: String
    +{abstract} execute(input: Map): ExecutionResult
    +{abstract} validate(result: ExecutionResult): boolean
}

enum Difficulty {
    BEGINNER
    INTERMEDIATE
    ADVANCED
    EXPERT
}

enum Category {
    DATA_STRUCTURES
    ALGORITHMS
    OS_CONCEPTS
    DATABASES
    SECURITY
    ML_AI
    CLOUD
    COMPILER
}

class AlgorithmConcept {
    -timeComplexity: String
    -spaceComplexity: String
    -pseudocode: String
    +execute(input: Map): ExecutionResult
    +validate(result: ExecutionResult): boolean
}

class DataStructureConcept {
    -operations: List<String>
    -invariants: List<String>
    +execute(input: Map): ExecutionResult
    +validate(result: ExecutionResult): boolean
    +visualize(): String
}

class ExecutionResult {
    -conceptId: String
    -input: Map
    -output: Object
    -executionMs: long
    -memoryBytes: long
    -correct: boolean
    -explanation: String
    -steps: List<String>
}

' ── Challenge Domain ─────────────────────────────────────────────────────────

class Challenge {
    -id: String
    -title: String
    -conceptId: String
    -testCases: List<TestCase>
    -constraints: String
    -solutionTemplate: String
    +grade(submission: Submission): GradeResult
}

class TestCase {
    -input: Map
    -expectedOutput: Object
    -hidden: boolean
    -timeoutMs: long
}

class Submission {
    -userId: String
    -challengeId: String
    -code: String
    -language: Language
    -submittedAt: Instant
}

enum Language {
    JAVA
    TYPESCRIPT
    PYTHON
    C_CPP
}

class GradeResult {
    -passed: int
    -total: int
    -score: double
    -feedback: String
    -executionMs: long
}

' ── Relationships ────────────────────────────────────────────────────────────

User "1" *-- "many" UserProgress : has
User "1" o-- "1" Leaderboard : ranked in

Concept <|-- AlgorithmConcept : extends
Concept <|-- DataStructureConcept : extends
Concept "1" *-- "1..*" Challenge : has

Challenge "1" *-- "1..*" TestCase : contains
Submission "many" --> "1" Challenge : submitted to
User "1" --> "many" Submission : makes
Challenge "1" --> "many" GradeResult : produces

AlgorithmConcept --> ExecutionResult : produces
DataStructureConcept --> ExecutionResult : produces

User --> UserRole : has role
Concept --> Category : belongs to
Concept --> Difficulty : has level
Submission --> Language : written in

note top of Concept : Abstract base — all 800+ concepts\nare instances of Concept subclasses

@enduml

