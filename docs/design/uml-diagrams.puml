@startuml UML_Component

' Concept #24 — UML Component Diagram
' Shows: high-level components and their provided/required interfaces

title Component Diagram — ConceptualWare System

component [React SPA] as spa {
    interface "REST Client" as rest_client
    interface "WebSocket Client" as ws_client
    interface "LocalStorage" as ls
}

component [API Gateway\nNode.js] as gateway {
    interface "REST API" as rest_api
    interface "WebSocket" as ws
    interface "Rate Limiter" as rl
    interface "Auth Middleware" as auth
}

component [Backend API\nSpring Boot] as backend {
    interface "Algorithm Executor" as algo_exec
    interface "Concept Registry" as registry
    interface "ML Engine" as ml
    interface "Compiler Engine" as compiler
}

component [MongoDB\nDocument Store] as mongodb
component [Redis\nCache + Pub/Sub] as redis
component [Neo4j\nGraph DB] as neo4j

spa --> gateway : REST HTTP/WS
gateway --> backend : HTTP
backend --> mongodb : Driver
backend --> redis : Lettuce
backend --> neo4j : Bolt

gateway ..> rl : uses
gateway ..> auth : uses
backend ..> algo_exec : uses
backend ..> registry : uses

@enduml

