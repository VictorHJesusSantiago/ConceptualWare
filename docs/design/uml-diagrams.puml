@startuml UML_SequenceDiagram

' Concept #24 — UML Sequence Diagram
' Shows: interaction between participants over time (message order matters)

title Sequence Diagram — Algorithm Execution Flow

actor Developer
participant "React SPA" as Frontend
participant "API Gateway" as Gateway
participant "Backend API" as Backend
participant "Cache (Redis)" as Cache
participant "MongoDB" as DB
participant "WebSocket" as WS

Developer -> Frontend : Select "Binary Search" concept
activate Frontend

Frontend -> Gateway : GET /api/v1/concepts/binary-search
activate Gateway

Gateway -> Gateway : Rate limit check (60 req/min)
Gateway -> Backend : GET /concepts/binary-search (forward)
activate Backend

Backend -> Cache : GET concept:binary-search
activate Cache
Cache --> Backend : MISS (not cached)
deactivate Cache

Backend -> DB : findById("binary-search")
activate DB
DB --> Backend : ConceptDocument
deactivate DB

Backend -> Cache : SET concept:binary-search TTL=10min
Backend --> Gateway : ConceptResponse (200 OK)
deactivate Backend

Gateway --> Frontend : ConceptResponse
deactivate Gateway

Frontend -> WS : CONNECT ws://api/ws/execute
activate WS

Developer -> Frontend : Submit execution with input [1,3,5,7,9], target=7

Frontend -> WS : EXECUTE {"conceptId": "binary-search", "input": {...}}
WS -> Backend : execute(request)
activate Backend

Backend -> Backend : BinarySearch.search([1,3,5,7,9], 7)
note right of Backend
  Step 1: mid=2, arr[2]=5 < 7 → search right half
  Step 2: mid=3, arr[3]=7 == 7 → FOUND at index 3
  Comparisons: 2
  Time: O(log n)
end note

Backend --> WS : PROGRESS {"step": 1, "lo": 0, "hi": 4, "mid": 2}
WS --> Frontend : Stream step 1

Backend --> WS : PROGRESS {"step": 2, "lo": 3, "hi": 4, "mid": 3, "found": true}
WS --> Frontend : Stream step 2

Backend --> WS : COMPLETE {"index": 3, "comparisons": 2, "correct": true}
deactivate Backend

Frontend -> Backend : POST /api/v1/submissions
activate Backend
Backend -> DB : save(submission)
Backend -> Backend : updateLeaderboard(userId, +10 points)
Backend --> Frontend : SubmissionResult
deactivate Backend

WS --> Frontend : Close connection
deactivate WS

Frontend --> Developer : Show result + explanation + steps
deactivate Frontend

@enduml

