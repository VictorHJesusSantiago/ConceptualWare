@startuml BPMN_AlgorithmExecution

' Concept #24 — BPMN (Business Process Model and Notation)
' BPMN 2.0 notation for algorithm execution workflow
' Swimlanes show which participant is responsible for each activity

title BPMN — Algorithm Execution Process

|Developer|
start

:Open concept page;
:Select algorithm variant;
:Configure input parameters;
:Click "Execute";

|API Gateway|

:Receive execution request;

if (Rate limit exceeded?) then (yes)
    :Return 429 Too Many Requests;
    stop
else (no)
endif

:Validate JWT token;

if (Token valid?) then (no)
    :Return 401 Unauthorized;
    stop
else (yes)
endif

:Forward request to backend;

|Backend|

:Check Redis cache;

if (Cache hit?) then (yes)
    :Return cached result;
    |Developer|
    :Display result from cache;
    stop
else (no)
endif

:Create isolated execution context;
:Apply resource limits (CPU, memory, timeout);

fork
    :Execute algorithm;
    :Record execution steps;
fork again
    :Start timeout watchdog (5s);
end fork

if (Execution timed out?) then (yes)
    :Kill execution thread;
    :Return TLE error;
    |Developer|
    :Show "Time Limit Exceeded";
    stop
else (no)
endif

if (Runtime error?) then (yes)
    :Capture error and stack trace;
    :Return error details;
    |Developer|
    :Show error message;
    stop
else (no)
endif

:Validate result correctness;
:Format execution result;

|Redis|
:Cache result (TTL 5 min);

|InfluxDB|
:Write execution metrics\n(timing, memory, correctness);

|Backend|
:Return result to gateway;

|API Gateway|
:Forward result to client;

|Developer|
:View execution result;
:See step-by-step visualization;
:Review time/space complexity;

if (Submit as challenge solution?) then (yes)
    |Backend|
    :Grade against test cases;
    :Compute score;
    :Update leaderboard;
    |Developer|
    :View grade and feedback;
endif

stop

@enduml

@startuml EventStorming

' Concept #24 — Event Storming Board
' Event Storming: collaborative technique to explore domain events
' Orange: Domain Events (past tense)
' Blue: Commands (triggers events)
' Yellow: Aggregates (consistency boundaries)
' Green: Policies (when event X, then command Y)
' Purple: External Systems

title Event Storming — ConceptualWare Domain

' User Registration Flow
rectangle "Register User" as CMD_REG #LightBlue
rectangle "UserRegistered" as EVT_REG #Orange
rectangle "Send Verification Email" as CMD_EMAIL #LightBlue
rectangle "EmailVerificationSent" as EVT_EMAIL #Orange

CMD_REG --> EVT_REG
EVT_REG --> CMD_EMAIL : Policy: on UserRegistered
CMD_EMAIL --> EVT_EMAIL

' Concept Execution Flow
rectangle "SelectConcept" as CMD_SEL #LightBlue
rectangle "ConceptSelected" as EVT_SEL #Orange
rectangle "ExecuteAlgorithm" as CMD_EXEC #LightBlue
rectangle "AlgorithmExecuted" as EVT_EXEC #Orange
rectangle "UpdateProgress" as CMD_PROG #LightBlue
rectangle "ProgressUpdated" as EVT_PROG #Orange
rectangle "UpdateLeaderboard" as CMD_LB #LightBlue
rectangle "LeaderboardUpdated" as EVT_LB #Orange

CMD_SEL --> EVT_SEL
EVT_SEL --> CMD_EXEC
CMD_EXEC --> EVT_EXEC
EVT_EXEC --> CMD_PROG : Policy: on successful execution
EVT_EXEC --> CMD_LB : Policy: on correct result
CMD_PROG --> EVT_PROG
CMD_LB --> EVT_LB

' Challenge Submission Flow
rectangle "SubmitSolution" as CMD_SUB #LightBlue
rectangle "SolutionSubmitted" as EVT_SUB #Orange
rectangle "GradeSubmission" as CMD_GRADE #LightBlue
rectangle "SubmissionGraded" as EVT_GRADE #Orange
rectangle "AwardBadge" as CMD_BADGE #LightBlue
rectangle "BadgeAwarded" as EVT_BADGE #Orange

CMD_SUB --> EVT_SUB
EVT_SUB --> CMD_GRADE : Policy: immediately
CMD_GRADE --> EVT_GRADE
EVT_GRADE --> CMD_BADGE : Policy: if score = 100 and first time
CMD_BADGE --> EVT_BADGE

note top of EVT_EXEC
  Domain Events captured in
  MongoDB audit collection
  and InfluxDB for metrics
end note

@enduml
