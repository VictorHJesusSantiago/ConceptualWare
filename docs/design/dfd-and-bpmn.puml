@startuml DFD_ConceptualWare

' Concept #24 — Data Flow Diagram (DFD)
' Shows: data flows between processes, data stores, and external entities
' Level 0 (Context diagram) and Level 1 (main processes)

title DFD — Level 0: Context Diagram

rectangle "Developer\n(External Entity)" as user #LightBlue
rectangle "GitHub OAuth\n(External Entity)" as github #LightGray
rectangle "Email Service\n(External Entity)" as email #LightGray

rectangle "ConceptualWare\nSystem" as system #LightYellow

user --> system : concept selection, code submission, execution requests
system --> user : algorithm results, learning progress, leaderboard scores

user --> github : OAuth2 authorization request
github --> system : user identity + access token

system --> email : verification emails, notifications
email --> user : email messages

@enduml

@startuml DFD_Level1

' DFD Level 1 — Main Processes
title DFD — Level 1: Main Processes

' External entities
rectangle "Developer" as dev  #LightBlue
rectangle "Admin"     as admin #LightBlue

' Processes (circles/bubbles)
circle "1.0\nAuthenticate\nUser" as P1
circle "2.0\nManage\nConcepts" as P2
circle "3.0\nExecute\nAlgorithm" as P3
circle "4.0\nGrade\nChallenge" as P4
circle "5.0\nUpdate\nLeaderboard" as P5
circle "6.0\nGenerate\nMetrics" as P6

' Data stores
database "D1: Users" as D1
database "D2: Concepts" as D2
database "D3: Submissions" as D3
database "D4: Results Cache\n(Redis)" as D4
database "D5: Metrics\n(InfluxDB)" as D5
database "D6: Leaderboard\n(Redis ZSET)" as D6

' Data flows
dev   --> P1 : credentials, OAuth token
P1    --> D1 : user record create/update
P1    --> dev : JWT token, session

dev   --> P2 : concept browse/search request
P2    --> D2 : query concepts
D2    --> P2 : concept data
P2    --> dev : concept list, details, theory

dev   --> P3 : algorithm input + parameters
P3    --> D4 : check cache
D4    --> P3 : cached result (hit)
P3    --> D2 : fetch concept implementation
P3    --> D3 : store execution result
P3    --> D5 : publish metrics
P3    --> D4 : cache result (miss)
P3    --> dev : execution result + visualization

dev   --> P4 : challenge submission (code)
P4    --> D2 : fetch test cases
P4    --> D3 : store submission
P4    --> P5 : trigger score update
P4    --> dev : grade result, feedback, hints

P5    --> D6 : update score
P5    --> D1 : update user progress
P5    --> dev : new rank notification

P6    --> D5 : query metrics
P6    --> admin : analytics dashboard, alerts

@enduml

