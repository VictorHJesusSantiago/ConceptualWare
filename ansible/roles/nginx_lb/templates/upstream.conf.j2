# Concept #22 — NGINX Upstream (Load Balancing)
#
# upstream block defines a pool of backend servers.
# NGINX distributes requests across them using the chosen method.
#
# keepalive: reuse TCP connections to upstream (reduces latency).
# max_fails / fail_timeout: passive health checks.

# API upstream — least_conn: new request to server with fewest active connections.
# Best for mixed short/long requests (avoids overloading slow servers).
upstream gateway_api {
    least_conn;

    {% for host in groups['app_servers'] %}
    server {{ hostvars[host]['ansible_host'] }}:{{ gateway_port }}
        max_fails=3
        fail_timeout=30s
        weight=1;
    {% endfor %}

    # Connection pooling to upstream
    keepalive 32;
    keepalive_requests 1000;
    keepalive_timeout 60s;
}

# WebSocket upstream — ip_hash: route same client to same backend.
# Required for WebSocket connections (stateful — tied to one server).
upstream gateway_ws {
    ip_hash;

    {% for host in groups['app_servers'] %}
    server {{ hostvars[host]['ansible_host'] }}:{{ gateway_port }};
    {% endfor %}
}
