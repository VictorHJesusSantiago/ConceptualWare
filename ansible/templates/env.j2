# Concept #22 — Ansible Template: .env file
#
# Rendered by Ansible, deployed to {{ app_dir }}/.env
# Mode 0600 (owner-read-only) — contains secrets.
# Tasks using this file set no_log: true.

# Application
APP_VERSION={{ app_version }}
APP_ENV=production

# JWT
JWT_SECRET={{ vault_jwt_secret }}

# MongoDB
MONGODB_URI=mongodb://{{ vault_mongodb_username }}:{{ vault_mongodb_password }}@{{ mongodb_host }}:{{ mongodb_port }}/{{ mongodb_database }}?replicaSet={{ mongodb_replica_set }}&authSource=admin

# Redis
REDIS_URL=redis://:{{ vault_redis_password }}@{{ redis_host }}:{{ redis_port }}

# Docker Registry
DOCKER_REGISTRY={{ docker_registry }}
DOCKER_REGISTRY_USER={{ vault_docker_registry_user }}
DOCKER_REGISTRY_PASSWORD={{ vault_docker_registry_password }}

# JVM
JAVA_OPTS=-Xms{{ java_heap_min }} -Xmx{{ java_heap_max }} -XX:+Use{{ java_gc }}
