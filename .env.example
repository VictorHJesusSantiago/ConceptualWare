# ConceptualWare — Environment Configuration
# Copy to .env and fill in real values (never commit .env to git)

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=changeme
MONGO_DATABASE=conceptualware
MONGO_URI=mongodb://root:changeme@mongodb:27017/conceptualware?authSource=admin

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_BASE64_64_CHARACTERS_MINIMUM_FOR_HMAC256
JWT_ACCESS_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=7

# ── Backend (Java/Spring Boot) ─────────────────────────────────────────────────
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# ── Gateway (TypeScript/Node.js) ───────────────────────────────────────────────
GATEWAY_PORT=3001
BACKEND_URL=http://backend:8080
NODE_ENV=production

# ── Frontend (React/Vite) ─────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001/api/v1
VITE_WS_URL=ws://localhost:8080/ws

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_API=60
RATE_LIMIT_AUTH=5
RATE_LIMIT_ALGO_EXEC=20

# ── Algorithm Execution ────────────────────────────────────────────────────────
ALGO_EXECUTION_TIMEOUT_MS=5000
ALGO_MAX_INPUT_SIZE=100000

# ── Redis (Concept #11: Key-Value Store) ───────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ── Neo4j (Concept #11: Graph Database) ───────────────────────────────────────
NEO4J_AUTH=neo4j/conceptualware
NEO4J_URI=bolt://neo4j:7687

# ── InfluxDB (Concept #11: Time-Series Database) ──────────────────────────────
INFLUX_USER=admin
INFLUX_PASSWORD=conceptualware
INFLUX_ORG=conceptualware
INFLUX_BUCKET=metrics
INFLUX_TOKEN=CHANGE_ME_GENERATE_WITH_INFLUX_CLI

# ── Security (Concept #21) ────────────────────────────────────────────────────
# MFA issuer name shown in authenticator apps
MFA_ISSUER=ConceptualWare
# Key rotation interval in milliseconds (default: 7 days)
SECURITY_KEY_ROTATION_MS=604800000
# SSL/TLS for mTLS
SSL_KEYSTORE_PASSWORD=CHANGE_ME
SSL_TRUSTSTORE_PASSWORD=CHANGE_ME
